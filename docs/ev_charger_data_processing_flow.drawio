        <mxCell id="e6" value="device command" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;strokeWidth=2;endArrow=block;endFill=1;strokeColor=#bf8700;fontSize=11;dashed=1;" edge="1" parent="1" source="backend-device" target="esp32">
