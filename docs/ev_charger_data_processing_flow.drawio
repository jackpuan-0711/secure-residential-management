          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e4" value="live station/session stream" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;strokeWidth=2;endArrow=block;endFill=1;strokeColor=#0969da;fontSize=11;dashed=1;" edge="1" parent="1" source="firestore" target="mobile">
