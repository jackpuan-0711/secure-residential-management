        </mxCell>
        <mxCell id="e5" value="future command: start / stop session" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;strokeWidth=2;endArrow=block;endFill=1;strokeColor=#bf8700;fontSize=11;dashed=1;" edge="1" parent="1" source="functions" target="backend-device">
          <mxGeometry relative="1" as="geometry" />
